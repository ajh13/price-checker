# eBay Developer credentials
# Get a free App ID at: https://developer.ebay.com/my/keys
EBAY_APP_ID=YourName-AppName-PRD-xxxxxxxxxxxx-xxxxxxxx

# eBay fetch settings
EBAY_MAX_RESULTS=120          # results to fetch per item (max 100 per page, multiple pages fetched)
EBAY_CONCURRENCY_LIMIT=3      # max simultaneous eBay API calls
EBAY_RATE_LIMIT=3.0           # max eBay API requests per second

# Cache settings
CACHE_TTL_HOURS=24            # how long results are cached
CACHE_DIR=.cache              # directory for cache file (override in Docker)

# Low-data threshold: if fewer than this many sales exist for a condition,
# show individual recent sales instead of aggregated stats
LOW_DATA_THRESHOLD=5
